{
	"name": "Ubuntu",
	"image": "mcr.microsoft.com/devcontainers/base:noble",
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:2": {},
		"ghcr.io/devcontainers/features/node:1": {},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/eitsupi/devcontainer-features/jq-likes:2": {},
		"ghcr.io/dhoeric/features/stern:1": {},
		"ghcr.io/rjfmachado/devcontainer-features/cloud-native:1": {},
		"ghcr.io/rio/features/k3d:1": {},
		"ghcr.io/rio/features/k9s:1": {},
		"ghcr.io/devcontainers-extra/features/kubie:1": {},
		"ghcr.io/meaningful-ooo/devcontainer-features/homebrew:2": {},
		"ghcr.io/devcontainers/features/copilot-cli:1": {}
	},
	"postCreateCommand": "brew install gastown dolt tmux sqlite",
	"postStartCommand": "mkdir -p /workspaces/cnpg-blue-green/.gt && cd /workspaces/cnpg-blue-green/.gt && (gt status > /dev/null 2>&1 || gt up) &",
	"onCreateCommand": "echo 'Setting up Gas Town cleanup hook...' && mkdir -p ~/.local/bin && cat > ~/.local/bin/gt-shutdown << 'EOF'\n#!/bin/bash\nif [ -d ${WORKSPACE_FOLDER}/.gt ]; then\n  cd ${WORKSPACE_FOLDER}/.gt\n  gt down 2>/dev/null || true\nfi\nEOF\nchmod +x ~/.local/bin/gt-shutdown",
	"customizations": {
		"vscode": {
			"extensions": [
				"GitHub.copilot-chat",
				"Mattickx.copilotignore-vscode",
				"emanuelebartolesi.vscode-copilot-insights"
			]
		}
	}
}