{
	"name": "Ubuntu",
	"image": "mcr.microsoft.com/devcontainers/base:noble",
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:2": {},
		"ghcr.io/devcontainers/features/node:1": {},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/eitsupi/devcontainer-features/jq-likes:2": {},
		"ghcr.io/dhoeric/features/stern:1": {},
		"ghcr.io/rjfmachado/devcontainer-features/cloud-native:1": {},
		"ghcr.io/rio/features/k3d:1": {},
		"ghcr.io/rio/features/k9s:1": {},
		"ghcr.io/devcontainers-extra/features/kubie:1": {},
		"ghcr.io/meaningful-ooo/devcontainer-features/homebrew:2": {},
		"ghcr.io/devcontainers/features/copilot-cli:1": {}
	},
	"postCreateCommand": "brew install gastown dolt tmux sqlite",
	"customizations": {
		"vscode": {
			"extensions": [
				"GitHub.copilot-chat",
				"Mattickx.copilotignore-vscode",
				"emanuelebartolesi.vscode-copilot-insights"
			]
		}
	}
}