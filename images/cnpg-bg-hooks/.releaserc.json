{
  "extends": "semantic-release-monorepo",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "semantic-release-replace-plugin",
      {
        "replacements": [
          {
            "files": ["../../charts/cnpg-bg/values.yaml"],
            "from": "    repository: m4s-b3n/cnpg-blue-green/cnpg-bg-hooks\n    tag: .*",
            "to": "    repository: m4s-b3n/cnpg-blue-green/cnpg-bg-hooks\n    tag: ${nextRelease.version}",
            "countMatches": true
          }
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["../../charts/cnpg-bg/values.yaml"],
        "message": "chore(cnpg-bg-hooks): release ${nextRelease.version} [skip ci]"
      }
    ],
    "@semantic-release/github"
  ]
}
